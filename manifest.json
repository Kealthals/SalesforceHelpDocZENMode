{
  "manifest_version": 3,
  "name": "Salesforce Help Doc ZEN Mode",
  "description": "Distraction-free reading mode for Salesforce help and developer documentation sites.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Salesforce Help Doc ZEN Mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://help.salesforce.com/s/articleView*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-inject.js"],
      "matches": ["https://help.salesforce.com/s/articleView*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
